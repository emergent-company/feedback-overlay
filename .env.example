# GitHub OAuth App credentials
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here
GITHUB_REDIRECT_URI=https://feedback.emergent-company.ai/auth/callback

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=change_me_to_a_random_32_byte_hex_string

# Server config
PORT=8080
DB_PATH=/data/feedback-overlay.db

# Comma-separated allowed CORS origins (use * to allow all)
ALLOWED_ORIGINS=*
