# GitHub App credentials
GITHUB_APP_ID=your_app_id_here
GITHUB_APP_CLIENT_ID=your_client_id_here
GITHUB_APP_CLIENT_SECRET=your_client_secret_here
GITHUB_REDIRECT_URI=https://feedback.emergent-company.ai/auth/callback

# GitHub App private key (PEM contents — replace newlines with \n for single-line env var)
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# GitHub App installation ID (find at: https://github.com/organizations/<org>/settings/installations)
GITHUB_INSTALLATION_ID=your_installation_id_here

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=change_me_to_a_random_32_byte_hex_string

# Server config
PORT=8080
DB_PATH=/data/feedback-overlay.db

# Comma-separated allowed CORS origins (use * to allow all)
ALLOWED_ORIGINS=*

# IP of your internal reverse proxy (e.g. Traefik) — used in extra_hosts so
# the container can resolve your public domain internally. Remove or leave
# blank if you use external DNS resolution instead.
TRAEFIK_HOST=
